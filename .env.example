# ─── ARE runtime configuration ───────────────────────────────────────────────
# Copy to `.env` (docker compose reads it automatically).

# HTTP port the ARE Node service listens on (inside the origin container).
PORT=3000

# Filesystem cache directory (persisted via Docker volume).
CACHE_DIR=./.cache

# Default TTL for ISR / Edge-ISR cached entries, in milliseconds.
CACHE_TTL_MS=30000

# Optional shared cache. Leave empty to disable Redis and use FS+memory only.
# In Docker the hostname is the compose service name.
REDIS_URL=redis://redis:6379

# Artificial latency this node injects (ms). Origin=0; edges override this.
EDGE_LATENCY_MS=0

# Marks responses so the analyzer knows it is behind an edge node.
# Origin leaves this empty; edge containers set it to their node id.
SERVED_BY=

# Where metrics records are written (persisted via Docker volume).
METRICS_DIR=./experiments/results/raw-data
